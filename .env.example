# Optional. The Site Speed feature calls the Google PageSpeed Insights API
# without a key by default, using Google's shared public quota — this works
# fine for occasional/local use but gets rate-limited quickly under real
# traffic. Get a free key and set it here for much higher limits:
#
#   1. https://console.cloud.google.com/ -> create (or pick) a project
#   2. APIs & Services -> Library -> enable "PageSpeed Insights API"
#   3. APIs & Services -> Credentials -> Create Credentials -> API key
#
# Never expose this as NEXT_PUBLIC_* — it's only read server-side.
PAGESPEED_API_KEY=

# --- Auth (required for login/register) ------------------------------------
# Any random long string. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=

# Google sign-in. Create an OAuth Client ID at
# https://console.cloud.google.com/apis/credentials
# (Application type: Web application; add
#  http://localhost:3000/api/auth/callback/google as an authorized
#  redirect URI for local dev).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

